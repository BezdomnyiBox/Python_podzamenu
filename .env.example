# Скопируйте в .env и настройте под себя
# cp .env.example .env

# Папка профиля Chrome (сессия WhatsApp сохраняется здесь)
# WHATSAPP_CHROME_PROFILE=/home/vladimir/.podzamenu/whatsapp_chrome

# Первый вход — false (нужен видимый браузер для QR)
# После авторизации можно true, но при слёте сессии снова понадобится false
WHATSAPP_HEADLESS=false

# HTTP API
WHATSAPP_API_HOST=127.0.0.1
WHATSAPP_API_PORT=8765
WHATSAPP_API_KEY=change-me-to-secret-key

# Пауза между сообщениями (сек) — снижает риск бана
WHATSAPP_SEND_DELAY_MIN=5
WHATSAPP_SEND_DELAY_MAX=15

# Таймауты (сек)
WHATSAPP_PAGE_LOAD_TIMEOUT=60
WHATSAPP_ELEMENT_WAIT_TIMEOUT=30

# Разрешённые коды стран (через запятую)
WHATSAPP_ALLOWED_COUNTRY_CODES=7

# Путь к Chrome, если не в PATH (Linux пример)
# CHROME_BINARY=/usr/bin/google-chrome

# --- WhatsApp Worker (опрос очереди CRM) ---
CRM_BASE_URL=https://crm.podzamenu.ru
CRM_AGENT_ID=office-main
CRM_AGENT_TOKEN=change-me-agent-token
CRM_POLL_INTERVAL_SEC=30
CRM_REQUEST_TIMEOUT=30
CRM_BATCH_LIMIT=5
